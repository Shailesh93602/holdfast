{
  "name": "quickcommerce-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Inventory reservation engine that never oversells under concurrency. Benchmarks pessimistic-lock vs optimistic-CAS vs atomic-conditional strategies against real Postgres.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "tsx src/infra/migrate.ts",
    "seed": "tsx src/infra/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx src/bench.ts",
    "typecheck": "tsc --noEmit",
    "loadtest": "k6 run loadtest/k6-reserve.js"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
